modules = ["python-3.12", "nodejs-20", "bash"]

[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[userenv]

[userenv.shared]
PORT = "5000"
DB_NAME = "llm_relay"
ADMIN_EMAIL = "admin@llmrelay.local"
LLM_PROVIDER = "ollama"
CORS_ORIGINS = "*"
LOG_LEVEL = "INFO"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80
