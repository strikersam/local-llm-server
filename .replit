modules = ["python-3.12", "nodejs-20", "bash"]

[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[userenv]

[userenv.shared]
PORT = "5000"
DB_NAME = "llm_wiki_dashboard"
ADMIN_EMAIL = "admin@llmrelay.local"
LLM_PROVIDER = "ollama"
CORS_ORIGINS = "*"
LOG_LEVEL = "INFO"
PROXY_STRIP_THINK_TAGS = "true"
PROXY_DEFAULT_MAX_TOKENS = "8192"
PROXY_DEFAULT_SYSTEM_PROMPT_ENABLED = "false"
RATE_LIMIT_RPM = "60"
OLLAMA_BASE = "https://incalculably-unswaggering-kora.ngrok-free.dev"
ADMIN_WINDOWS_AUTH = "false"
LANGFUSE_BASE_URL = "https://cloud.langfuse.com"
FRONTEND_URL = "https://strikersam.github.io/local-llm-server"
GITHUB_CALLBACK_URL = "https://local-llm-server.onrender.com/api/github/oauth/callback"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80
