#!/usr/bin/env sh
# pre-push — run tests before pushing to remote
#
# Runs pytest (fast fail) before any push.
# This catches test failures that weren't caught locally before they hit CI.
#
# Activate with: git config core.hooksPath .claude/hooks
#
# Skip (emergency only): git push --no-verify
#   Note: CI will still run and may block the PR.

set -e

RED='\033[0;31m'
GRN='\033[0;32m'
YLW='\033[0;33m'
RST='\033[0m'

_info()  { printf "  ${GRN}✓${RST} %s\n" "$1"; }
_error() { printf "  ${RED}✗${RST} %s\n" "$1"; }
_head()  { printf "\n${GRN}[pre-push]${RST} %s\n" "$1"; }

_head "Running test suite before push..."

# Find python/pytest
PYTEST=""
if [ -f ".venv/bin/pytest" ]; then
    PYTEST=".venv/bin/pytest"
elif command -v pytest >/dev/null 2>&1; then
    PYTEST="pytest"
else
    printf "  ${YLW}⚠${RST} pytest not found — skipping test run\n"
    printf "  ${YLW}⚠${RST} Install with: pip install pytest --break-system-packages\n"
    exit 0
fi

# Run tests — fail fast, quiet output (show only failures)
if ! $PYTEST -x -q 2>&1; then
    echo ""
    _error "Tests FAILED. Push blocked."
    _error "Fix failing tests before pushing."
    echo ""
    echo "  To run tests manually: pytest -x"
    echo "  To skip this hook (NOT recommended): git push --no-verify"
    echo ""
    exit 1
fi

_info "All tests passed. Proceeding with push."
exit 0
