#!/usr/bin/env sh
# pre-commit — blocking guardrails for local-llm-server
#
# Activate with: git config core.hooksPath .claude/hooks
#
# Checks:
#   1. Python syntax on all staged .py files
#   2. No hardcoded secrets / env-variable mistakes in staged files
#   3. No keys.json staged
#   4. No .env staged (only .env.example is allowed)
#
# Fast checks only — pytest runs in pre-push (slower).

set -e

PASS=0
FAIL=1

RED='\033[0;31m'
YLW='\033[0;33m'
GRN='\033[0;32m'
RST='\033[0m'

_info()  { printf "  ${GRN}✓${RST} %s\n" "$1"; }
_warn()  { printf "  ${YLW}⚠${RST} %s\n" "$1"; }
_error() { printf "  ${RED}✗${RST} %s\n" "$1"; }
_head()  { printf "\n${GRN}[pre-commit]${RST} %s\n" "$1"; }

ERRORS=0

_head "Running pre-commit checks..."

# ── 1. Block committed secrets ─────────────────────────────────────────────────

if git diff --cached --name-only | grep -qE '^\.env$'; then
    _error "BLOCKED: .env is staged. Remove it: git reset HEAD .env"
    ERRORS=$((ERRORS + 1))
fi

if git diff --cached --name-only | grep -qE '^keys\.json$'; then
    _error "BLOCKED: keys.json is staged. This file contains API keys and must never be committed."
    _error "  Remove it: git reset HEAD keys.json"
    ERRORS=$((ERRORS + 1))
fi

# ── 2. Check for hardcoded secrets in staged Python files ─────────────────────

STAGED_PY=$(git diff --cached --name-only | grep '\.py$' || true)

if [ -n "$STAGED_PY" ]; then
    for f in $STAGED_PY; do
        [ -f "$f" ] || continue
        # Pattern: SECRET_KEY = "literal" (not os.environ / os.getenv)
        if grep -nE 'SECRET_KEY\s*=\s*["\x27][^"]+["\x27]' "$f" 2>/dev/null; then
            _error "Hardcoded SECRET_KEY in $f — use os.environ.get() instead"
            ERRORS=$((ERRORS + 1))
        fi
        # Pattern: password = "literal" (assignment, not function call)
        if grep -nE '^\s*(password|passwd|api_key|token)\s*=\s*["\x27][a-zA-Z0-9_\-\.]{8,}["\x27]' "$f" 2>/dev/null; then
            _warn "Possible hardcoded credential in $f — review before pushing"
        fi
    done
fi

# ── 3. Python syntax check on staged files ────────────────────────────────────

if [ -n "$STAGED_PY" ]; then
    PYTHON=$(command -v python3 || command -v python || echo "")
    if [ -n "$PYTHON" ]; then
        for f in $STAGED_PY; do
            [ -f "$f" ] || continue
            if ! $PYTHON -m py_compile "$f" 2>/dev/null; then
                _error "Python syntax error in $f"
                $PYTHON -m py_compile "$f"
                ERRORS=$((ERRORS + 1))
            fi
        done
        _info "Python syntax OK (${STAGED_PY})"
    else
        _warn "python3 not found — skipping syntax check"
    fi
fi

# ── 4. Block TODO-only stub functions in critical paths ───────────────────────

RISKY_PATHS="admin_auth.py key_store.py agent/tools.py agent/loop.py"
for f in $RISKY_PATHS; do
    if git diff --cached --name-only | grep -qF "$f"; then
        # Check if the file has any function that is ONLY a TODO comment or 'pass'
        if grep -nE '^\s+TODO|^\s+\.\.\.\s*$' "$f" 2>/dev/null | grep -v "^Binary" | head -5; then
            _warn "$f has TODO/... stubs — confirm these are intentional before merging to main"
        fi
    fi
done

# ── Result ─────────────────────────────────────────────────────────────────────

echo ""
if [ "$ERRORS" -gt 0 ]; then
    _error "pre-commit FAILED with $ERRORS error(s). Fix before committing."
    exit $FAIL
fi

_info "All pre-commit checks passed."
exit $PASS
