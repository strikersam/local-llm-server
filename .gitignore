# Secrets — never commit
.env
/.pytest_cache/
tests/__pycache__/
__pycache__/
keys.json

# Runtime state
server.pids
logs/
*.pid
*.log

# Python cache
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Web UI build artifacts
webui/frontend/node_modules/
webui/frontend/dist/
webui/frontend/*.tsbuildinfo

# Web UI server-side config store (providers/workspaces)
.data/

# Local agent tooling (not part of runtime repo)
.agents/

# OS / editor
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/

# Claude Code ephemeral session state — do NOT commit these
.claude/settings.local.json
.claude/sessions/
.claude/todos
# But DO commit project-level AI engineering files in .claude/
# (skills, hooks, commands, agents, state are intentionally versioned)
