# Copy this file to .env and fill in your values.
# Never commit .env to git — it contains your secret API keys.

# ── API Keys ──────────────────────────────────────────────────────────────────
# Option A — Legacy: comma-separated Bearer tokens (optional if you use KEYS_FILE).
# Option B — Recommended: JSON key store with per-user email + department (seat).
#   Set KEYS_FILE and run:  python generate_api_key.py --email user@co.com --department engineering
#
# Generate a secure legacy key:
#   Linux/macOS:  openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
#   Windows PS:   $rng = New-Object System.Security.Cryptography.RNGCryptoServiceProvider
#                 $bytes = New-Object byte[] 32; $rng.GetBytes($bytes)
#                 [Convert]::ToBase64String($bytes).Replace("+","-").Replace("/","_").TrimEnd("=")

API_KEYS=your-secret-key-here,optional-second-key-for-another-device

# Path to JSON key database (hashed secrets). Ignored if empty.
KEYS_FILE=keys.json

# ── Langfuse (optional) — usage + estimated “savings” vs commercial API pricing ─
# Create a project at https://cloud.langfuse.com and paste keys. Leave blank to disable.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# Official name from Langfuse; cloud default below. Alias: LANGFUSE_HOST (same value).
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Commercial-equivalent USD per 1M tokens (optional overrides; defaults are built-in for common models).
# COMMERCIAL_EQUIVALENT_PRICES_FILE=pricing.json
# COMMERCIAL_EQUIVALENT_PRICES_JSON={"my-local-model:tag":{"commercial_name":"GPT-4.1","input_per_million_usd":2,"output_per_million_usd":8}}

# Set false if your Ollama build rejects stream_options on /v1/chat/completions
# PROXY_INJECT_STREAM_USAGE=true

# Inject a default system prompt into chat requests.
# Recommended for generic clients, but disable it for Continue so you do not stack
# a proxy prompt on top of Continue's own rules/system message.
PROXY_DEFAULT_SYSTEM_PROMPT_ENABLED=false
PROXY_DEFAULT_SYSTEM_PROMPT_FILE=templates/codex_local_ide_system_prompt.txt

# Remove <think>...</think> blocks from chat responses when the model exposes them.
PROXY_STRIP_THINK_TAGS=true

# Safety cap applied only when the client does not send max_tokens.
# IMPORTANT: Claude Code needs at least 4096. Set to 0 to disable the cap entirely.
# 1200 is too low for Claude Code — it will truncate every code generation response.
PROXY_DEFAULT_MAX_TOKENS=8192

# Local coding agent defaults. These power the /agent/* endpoints:
# - planner: breaks a natural-language request into steps
# - executor: inspects files and writes full-file replacements
# - verifier: checks whether a proposed change is valid
AGENT_PLANNER_MODEL=deepseek-r1:32b
AGENT_EXECUTOR_MODEL=qwen3-coder:30b
AGENT_VERIFIER_MODEL=deepseek-r1:32b

# Optional explicit workspace root for agent file tools. Defaults to the repo root.
# AGENT_WORKSPACE_ROOT=C:\path\to\repo

# Langfuse: if the Python SDK fails to send events, force REST-only ingestion:
# LANGFUSE_USE_HTTP_ONLY=true
# Optional: flush SDK queue sooner (integer batch size, e.g. 1)
# LANGFUSE_FLUSH_AT=1

# Browser admin UI (after login): http://localhost:8000/admin/ui/
# Uses the same ADMIN_SECRET as POST /admin/keys.

# ── Model Storage ─────────────────────────────────────────────────────────────
# Directory where Ollama stores downloaded model weights.
# Use a drive with plenty of free space (671B needs ~404 GB).
#
# Windows:  OLLAMA_MODELS=D:\aipc-models
# Linux:    OLLAMA_MODELS=/mnt/data/ollama-models
# macOS:    OLLAMA_MODELS=/Volumes/Data/ollama-models
# Default:  (leave blank to use Ollama's default ~/.ollama/models)

OLLAMA_MODELS=D:\aipc-models

# ── Executable Paths (optional) ───────────────────────────────────────────────
# Leave blank to auto-detect from PATH.
# Set explicitly if Ollama/Python/cloudflared are not on your PATH.
#
# Windows example (Intel AI PC bundled Ollama):
#   OLLAMA_EXE=C:\path\to\ollama.exe
# Windows example (Python not on PATH):
#   PYTHON_EXE=C:\path\to\python.exe
# Windows example (cloudflared install location):
#   CLOUDFLARED_EXE=C:\Program Files (x86)\cloudflared\cloudflared.exe

OLLAMA_EXE=
# Windows: use full path if `python` is missing (Store alias). Example:
# PYTHON_EXE=C:\Users\swami\AppData\Local\Programs\Python\Python312\python.exe
PYTHON_EXE=
CLOUDFLARED_EXE=

# ── Admin API (optional) ──────────────────────────────────────────────────────
# If set, enables POST /admin/keys with JSON {"email":"...","department":"..."} and header
# X-Admin-Secret: <ADMIN_SECRET> or Authorization: Bearer <ADMIN_SECRET>
# Requires KEYS_FILE. Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET=
# On Windows, lets /admin/ui/login and /admin/api/login validate local Windows credentials.
ADMIN_WINDOWS_AUTH=true
# Optional comma-separated allow-list for admin logins, e.g. HOSTNAME\swami,swami
ADMIN_WINDOWS_ALLOWED_USERS=

# ── Dynamic Model Routing ────────────────────────────────────────────────────
# Automatic model selection based on task type (code vs reasoning vs conversation).
# All routing decisions are recorded in Langfuse as routing_* metadata fields.
#
# Manual override — force a specific model for any request from any client:
#   HTTP header:  X-Model-Override: deepseek-r1:32b
#   This takes highest priority and sets routing_mode=manual in traces.
#
# Add extra models to the capability registry without code changes.
#   Format (3 colon-separated parts, comma-separated entries):
#     model_name:type:strength1+strength2+strength3
#   Types: coder | reasoning | general
#   Strengths: code_generation | code_debugging | tool_use | reasoning |
#              fast_response | long_context | conversation | analysis
# ROUTER_EXTRA_MODELS=my-coder:coder:code_generation+tool_use,my-llm:reasoning:reasoning+analysis
#
# Disable Ollama health checks (skips unavailable-model filtering):
# ROUTER_HEALTH_CHECK_ENABLED=true
#
# How long to cache the list of loaded Ollama models (seconds, default 60):
# ROUTER_HEALTH_CACHE_TTL=60
#
# Max combined message length (chars) to qualify for fast_response routing (default 200):
# ROUTER_FAST_RESPONSE_CHARS=200

# ── Claude Code / Anthropic API Compatibility ─────────────────────────────────
# Enables Claude Code CLI: set ANTHROPIC_BASE_URL=https://your-tunnel-url
# Maps Anthropic model names → local Ollama model names (comma-separated).
# Format: anthropic_model_name:local_model_name
# Special key * is the catch-all fallback.
# Built-in defaults map all Claude 3.x/4.x names to qwen3-coder:30b or deepseek-r1:32b.
# MODEL_MAP=claude-sonnet-4-6:qwen3-coder:30b,claude-opus-4-6:deepseek-r1:32b,claude-haiku-4-5-20251001:qwen3-coder:7b,claude-3-5-sonnet-20241022:qwen3-coder:30b,*:qwen3-coder:30b
#
# Extended map — add after pulling with .\download_models.ps1 -Extended:
#   minimax-m2.5 is a 229B MoE (10B active) local GGUF (~138 GB). Route via model name:
# MODEL_MAP=...,minimax-m2.5:frob/minimax-m2.5:230b-a10b-q4_K_M
#
# Cloud-proxy models — add after pulling with .\download_models.ps1 -CloudProxy:
#   These route through Ollama to vendor APIs; vendor API key must be set in Ollama env.
# MODEL_MAP=...,deepseek-v3.2:deepseek-v3.2:cloud,minimax-m2.7:minimax-m2.7:cloud,glm-5-turbo:glm-5:cloud
#
# Not yet available locally (as of 2026-03-31):
#   - MiMo-V2-Pro (Xiaomi) — proprietary, no released weights
#   - Step 3.5 Flash (stepfun) — open source Apache 2.0 (111 GB Q4) but not in Ollama yet;
#     download via: huggingface-cli download stepfun-ai/Step-3.5-Flash-GGUF

# ── Local Infrastructure Cost Tracking ────────────────────────────────────────
# Measured values for your specific hardware (used for true TCO analysis in Langfuse).
# Run: python infra_cost.py to see projected costs with current settings.
# IMPORTANT: Measure these with GPU-Z / HWiNFO64 / a smart-plug watt meter.
#
# Intel AI PC (Lunar Lake / Meteor Lake with Arc iGPU):
#   INFRA_GPU_ACTIVE_WATTS=35   INFRA_GPU_IDLE_WATTS=8   INFRA_SYSTEM_WATTS=25
# RTX 4090 workstation:
#   INFRA_GPU_ACTIVE_WATTS=250  INFRA_GPU_IDLE_WATTS=20  INFRA_SYSTEM_WATTS=80
INFRA_GPU_ACTIVE_WATTS=150
INFRA_GPU_IDLE_WATTS=20
INFRA_SYSTEM_WATTS=50
INFRA_ELECTRICITY_USD_KWH=0.12
INFRA_HARDWARE_COST_USD=2000
INFRA_AMORTIZATION_MONTHS=36
# INFRA_MODEL_STORAGE_GB=20
# INFRA_STORAGE_USD_GB_MO=0.023

# ── Telegram Bot (optional — remote command/control) ──────────────────────────
# 1. Create a bot via @BotFather — paste the token here
# 2. Get your user ID via @userinfobot
# 3. Run: python telegram_bot.py
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to query status (read-only)
TELEGRAM_ALLOWED_USER_IDS=
# Subset of ALLOWED that can run start/stop/agent commands (admin)
TELEGRAM_ADMIN_USER_IDS=
# API key this bot uses to call /admin/* endpoints — use your ADMIN_SECRET value
# TELEGRAM_PROXY_API_KEY=
# Proxy base URL the bot connects to (default: local port 8000)
# PROXY_BASE_URL=http://localhost:8000

# ── Server Config ─────────────────────────────────────────────────────────────
OLLAMA_BASE=http://localhost:11434
PROXY_PORT=8000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max requests per minute per API key (prevents runaway usage)
RATE_LIMIT_RPM=60

# ── CORS (browser clients) ────────────────────────────────────────────────────
# Comma-separated allowed Origin values, or * for any origin (default).
# Example: CORS_ORIGINS=https://myapp.example.com
CORS_ORIGINS=*

# ── Logging ──────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
