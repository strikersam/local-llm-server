# LLM Relay — Environment Configuration
# Copy to .env and fill in your values. Never commit .env to git.

# ── Database ────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=llm_relay

# ── Auth ────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
ADMIN_EMAIL=admin@llmrelay.local
ADMIN_PASSWORD=change-me-to-a-strong-password
ADMIN_SECRET=

# ── LLM Provider ───────────────────────────────────────────
# Options: ollama, emergent
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434

# ── Langfuse (optional) ───────────────────────────────────
# Create project at https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Public Access / ngrok (optional) ──────────────────────
NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# ── API Keys ──────────────────────────────────────────────
# Legacy comma-separated Bearer tokens (optional)
API_KEYS=
KEYS_FILE=keys.json

# ── Proxy Config ──────────────────────────────────────────
PROXY_PORT=8000
PROXY_DEFAULT_MAX_TOKENS=8192
PROXY_STRIP_THINK_TAGS=true
RATE_LIMIT_RPM=60
CORS_ORIGINS=*
LOG_LEVEL=INFO

# ── Agent Models ──────────────────────────────────────────
AGENT_PLANNER_MODEL=deepseek-r1:32b
AGENT_EXECUTOR_MODEL=qwen3-coder:30b
AGENT_VERIFIER_MODEL=deepseek-r1:32b

# ── Ollama Config ─────────────────────────────────────────
OLLAMA_MODELS=~/.ollama/models
OLLAMA_EXE=
PYTHON_EXE=
CLOUDFLARED_EXE=

# ── Infrastructure Cost Tracking ──────────────────────────
INFRA_GPU_ACTIVE_WATTS=150
INFRA_GPU_IDLE_WATTS=20
INFRA_SYSTEM_WATTS=50
INFRA_ELECTRICITY_USD_KWH=0.12
INFRA_HARDWARE_COST_USD=2000
INFRA_AMORTIZATION_MONTHS=36
