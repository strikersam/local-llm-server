# LLM Proxy — Environment Configuration
# Copy to .env and fill in your values. Never commit .env to git.

# ── Auth ────────────────────────────────────────────────────────────────────
# Comma-separated Bearer tokens for API clients (Claude Code, Cursor, Aider…)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=

# ⚠️  ADMIN PORTAL LOGIN — set ADMIN_SECRET below to any strong random string,
#     then log in at  http://<host>:<port>/admin/ui/login  using:
#         Username: anything (e.g. `admin`)
#         Password: the value of ADMIN_SECRET
#     (ADMIN_PASSWORD further down is the *dashboard user* login, not this one.)
# Secret for /admin/* management endpoints and the browser admin dashboard.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET=

# Path to JSON key-store (persistent API key management, optional)
KEYS_FILE=keys.json

# ── Ollama ──────────────────────────────────────────────────────────────────
# URL of your Ollama instance.
#
# Local (same machine / Docker):
OLLAMA_BASE=http://localhost:11434
# Dashboard backend also understands OLLAMA_BASE_URL (alias):
OLLAMA_BASE_URL=http://localhost:11434
# Default dashboard model (used by seeded "Ollama (Local)" provider):
OLLAMA_MODEL=llama3.2
#
# Windows machine via Cloudflare Tunnel (free, no port-forwarding needed):
#   1. On Windows, install cloudflared:
#        winget install --id Cloudflare.cloudflared
#   2. Start a quick tunnel exposing Ollama:
#        cloudflared tunnel --url http://localhost:11434
#   3. Copy the *.trycloudflare.com URL here (or use a named tunnel for
#      a permanent subdomain — see https://cloudflare.com/products/tunnel)
# OLLAMA_BASE=https://xxxx.trycloudflare.com
#
# ngrok alternative (free tier, changes URL on restart):
#   ngrok http 11434
# OLLAMA_BASE=https://xxxx.ngrok-free.app

# ── Langfuse observability (optional) ────────────────────────────────────────
# Create a project at https://cloud.langfuse.com (free tier available)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Hugging Face (serverless / free tier) ───────────────────────────────────
# The dashboard seeds a "Hugging Face (Serverless)" provider pointing at the
# OpenAI-compatible HF router. Token is optional but recommended.
HF_TOKEN=
# Alternate name for the token:
HUGGINGFACE_API_TOKEN=
# OpenAI-compatible router base:
HF_BASE_URL=https://router.huggingface.co
# Default model for the seeded provider (you can override in the UI):
HF_MODEL_ID=Qwen/Qwen2.5-Coder-7B-Instruct

# ── Public access / tunnels (docker-compose profiles) ────────────────────────
# For Cloudflare Tunnel profile (docker compose --profile tunnel up):
# No token needed for quick tunnels. For permanent subdomain:
#   CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token

# For ngrok profile (docker compose --profile ngrok up):
NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# ── Proxy config ─────────────────────────────────────────────────────────────
PROXY_PORT=8000
PROXY_DEFAULT_MAX_TOKENS=8192
PROXY_STRIP_THINK_TAGS=false
RATE_LIMIT_RPM=60
CORS_ORIGINS=*
LOG_LEVEL=INFO

# Browser automation (optional; disabled by default in tests/CI).
BROWSER_AUTOMATION_ENABLED=false

# ── Dashboard (Web UI on :3000 + API on :8001) ──────────────────────────────
# This is the "LLM Relay" dashboard shown in the README screenshots.
MONGO_URL=mongodb://localhost:27017
DB_NAME=llm_wiki_dashboard
# Stable JWT secret recommended (generate once and keep private):
JWT_SECRET=
ADMIN_EMAIL=admin@llmrelay.local
ADMIN_PASSWORD=
# Which seeded provider should be default: "ollama" or "huggingface"
LLM_PROVIDER=ollama
# Allowed origin for browser clients (when developing locally):
FRONTEND_URL=http://localhost:3000

# ── Model routing ─────────────────────────────────────────────────────────────
# Default models (Ollama model names)
AGENT_EXECUTOR_MODEL=qwen3-coder:30b
AGENT_PLANNER_MODEL=deepseek-r1:32b
AGENT_VERIFIER_MODEL=deepseek-r1:32b

# Override which local model handles each Claude/OpenAI alias (comma-separated).
# Format: anthropic-alias:local-model,anthropic-alias2:local-model2
# Example for smaller/faster models on limited hardware:
#   MODEL_MAP=claude-sonnet-4-6:qwen3-coder:14b,claude-opus-4-6:deepseek-r1:14b
MODEL_MAP=

# Add extra models to the routing registry at runtime:
#   ROUTER_EXTRA_MODELS=my-model:7b:coder:code_generation+tool_use
ROUTER_EXTRA_MODELS=

# ── Claude Code / Cursor / Aider / Continue ──────────────────────────────────
# To use this proxy with Claude Code:
#   export ANTHROPIC_BASE_URL=http://localhost:8000   (or your Render/tunnel URL)
#   export ANTHROPIC_API_KEY=<one of your API_KEYS above>
#   claude                                             (Claude Code CLI)
#
# To use with Cursor / Continue / Aider (OpenAI-compatible):
#   Base URL:  http://localhost:8000/v1  (or your Render/tunnel URL + /v1)
#   API Key:   <one of your API_KEYS above>
#   Model:     claude-sonnet-4-6  (or any alias from /v1/models)

# ── Agent models ──────────────────────────────────────────────────────────────
# Models used internally by the agent loop (must be available in Ollama)
# Leave defaults unless you have different models pulled.

# ── Infrastructure cost tracking (optional) ──────────────────────────────────
INFRA_GPU_ACTIVE_WATTS=150
INFRA_GPU_IDLE_WATTS=20
INFRA_SYSTEM_WATTS=50
INFRA_ELECTRICITY_USD_KWH=0.12
INFRA_HARDWARE_COST_USD=2000
INFRA_AMORTIZATION_MONTHS=36

# ── Social Login — GitHub & Google (optional) ────────────────────────────────
# Register at:
#   GitHub: https://github.com/settings/developers
#   Google: https://console.cloud.google.com/apis/credentials
#
# GitHub Settings:
#   Homepage URL:  http://localhost:3000
#   Redirect URL:  http://localhost:8001/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Google Settings:
#   Redirect URL:  http://localhost:8001/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

